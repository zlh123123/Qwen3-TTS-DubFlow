FROM python:3.11-slim

ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
ARG API_MODULE=services.qwen_voice_design_api:app
ARG API_PORT=8001

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    API_MODULE=${API_MODULE} \
    API_PORT=${API_PORT} \
    PYTHONPATH=/app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        ffmpeg \
        sox \
        libsox-dev \
        libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY services /app/services
COPY Qwen3-TTS /app/Qwen3-TTS

RUN pip install --upgrade pip \
    && pip install torch torchvision torchaudio --index-url ${TORCH_INDEX_URL} \
    && pip install -r /app/services/requirements-api.txt \
    && pip install -e /app/Qwen3-TTS

EXPOSE ${API_PORT}

CMD ["sh", "-lc", "uvicorn ${API_MODULE} --host 0.0.0.0 --port ${API_PORT}"]
