# Shared torch wheel source (GPU: cu121, CPU: https://download.pytorch.org/whl/cpu)
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121

# Shared HuggingFace cache (model downloads)
HF_HOME_DIR=./volumes/hf-home

# For users in Mainland China, you may set:
# HF_ENDPOINT=https://hf-mirror.com

# ==================== Qwen3-TTS ====================
QWEN_GPUS=all
QWEN_DEVICE=cuda:0
QWEN_DTYPE=bfloat16
QWEN_ATTN_IMPLEMENTATION=
QWEN_MODEL_LOCAL_FILES_ONLY=0
QWEN_MODELS_DIR=./volumes/qwen-models

QWEN_VOICE_DESIGN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
QWEN_VOICE_CLONE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_VOICE_DESIGN_PORT=8001
QWEN_VOICE_CLONE_PORT=8002

# ==================== Fish-Speech ====================
FISH_GPUS=all
FISH_BACKEND=cuda
FISH_CUDA_VER=12.9.0
FISH_UV_EXTRA=cu129
FISH_UV_VERSION=0.8.15
FISH_COMPILE=0
FISH_API_PORT=8080
FISH_AUTO_DOWNLOAD=1
FISH_HF_REPO=fishaudio/s2-pro
FISH_HF_LOCAL_DIR=/app/checkpoints/s2-pro

FISH_CHECKPOINTS_DIR=./fish-speech/checkpoints
FISH_REFERENCES_DIR=./fish-speech/references
FISH_LLAMA_CHECKPOINT_PATH=checkpoints/s2-pro
FISH_DECODER_CHECKPOINT_PATH=checkpoints/s2-pro/codec.pth
FISH_DECODER_CONFIG_NAME=modded_dac_vq

# If you need to access private/gated HuggingFace repos:
HUGGING_FACE_HUB_TOKEN=

# ==================== MeanAudio ====================
MEANAUDIO_GPUS=all
MEANAUDIO_DEVICE=cuda
MEANAUDIO_VARIANT=meanaudio_s
MEANAUDIO_PORT=8003
MEANAUDIO_AUTO_DOWNLOAD=1
MEANAUDIO_ENCODER=t5_clap
MEANAUDIO_USE_ROPE=1
MEANAUDIO_TEXT_C_DIM=512
MEANAUDIO_FULL_PRECISION=0
MEANAUDIO_HF_REPO=AndreasXi/MeanAudio
MEANAUDIO_WEIGHTS_DIR=./MeanAudio/weights
