{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qwen3 TTS DubFlow",
  "version": "0.1.0",
  "identifier": "com.dubflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Qwen3 TTS DubFlow",
        "width": 1220,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 700,
        "center": true,
        "maximized": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
